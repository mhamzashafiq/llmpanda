**/node_modules/

# ── Build outputs ───────────────────────────────────────────────
**/dist/
**/.vite/
**/out/

# ── Secrets & local data (NEVER commit) ─────────────────────────
**/.env
**/.env.local
**/.env.*.local
!**/.env.example
**/server/data/
**/*.db
**/*.db-wal
**/*.db-shm
**/encryption.key
*.pem
*.key
*.keystore

