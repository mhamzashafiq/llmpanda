# ── LLM Panda env ──────────────────────────────────────────────────────────
# Copy to .env (gitignored) and fill in. Loaded by server/src/env.ts (dotenv).

# REQUIRED — master Key-Encryption-Key (KEK) that wraps every org's data key.
# 64 hex chars (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: lose this and every stored provider key is permanently undecryptable.
# Back it up + keep it in a secrets manager (not a plaintext file) in production.
ENCRYPTION_KEY=your-64-char-hex-key-here

# REQUIRED in prod — Supabase/Postgres connection string.
# Dev defaults to the local Docker Supabase if unset.
# DATABASE_URL=postgresql://user:pass@host:5432/postgres

# Server port (default: 3001)
PORT=3001

# ── Production hardening ─────────────────────────────────────────────────────
# Turns on CSP + HSTS + trust-proxy + CORS lockdown.
# NODE_ENV=production
# Public dashboard base URL — used in verification / password-reset email links.
# APP_URL=https://app.yourdomain.com
# Comma-separated allowed dashboard origins for CORS. In production the localhost
# defaults are dropped, so this MUST be set to your public dashboard URL(s).
# DASHBOARD_ORIGINS=https://app.yourdomain.com

# ── Rate limits (requests/min/IP; 0 disables) ───────────────────────────────
# PROXY_RATE_LIMIT_RPM=120
# AUTH_RATE_LIMIT_RPM=30

# ── Keyless image generation (optional) ──────────────────────────────────────
# Pollinations is a no-key (anonymous) model. A free token (auth.pollinations.ai)
# only lifts the shared-IP rate cap for the keyless image route — it is NOT a
# per-user provider key; users still bring their own keys for every keyed model.
# POLLINATIONS_TOKEN=

# ── GitHub OAuth (optional "Continue with GitHub") ───────────────────────────
# Create an OAuth App at github.com/settings/developers. Authorization callback
# URL must be: <APP_URL>/api/auth/github/callback  (e.g. https://llmpanda.io/api/auth/github/callback)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Email (SMTP) — verification + password reset ─────────────────────────────
# If unset, the links are logged to the server console instead of emailed
# (dev / no provider). Email verification is REQUIRED to log in.
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=LLM Panda <no-reply@yourdomain.com>

# ── Error monitoring (optional) ──────────────────────────────────────────────
# Server uses SENTRY_DSN; the browser build uses VITE_SENTRY_DSN (build-time).
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# ── Billing (later — Stripe). Blank = billing endpoints stay disabled. ────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Docker only: host interface the container's port publishes on (default 127.0.0.1).
# HOST_BIND=0.0.0.0
